<launch>
        <arg name="ros_ip"     default="$(optenv ROS_IP 127.0.0.1)"/>
<!--        <arg name="fcu_url" default="/dev/ttyAMA0:230400" /> -->
        <arg name="fcu_url" default="udp://127.0.0.1:14551@" />
        <arg name="gcs_url" default="udp://$(arg ros_ip):14445@" />
        <arg name="tgt_system" default="112" />
        <arg name="tgt_component" default="1" />
        <arg name="log_output" default="screen" />
        <arg name="fcu_protocol" default="v2.0" />
        <arg name="respawn_mavros" default="true" />

        <include file="$(find mavros)/launch/node.launch">
                <arg name="pluginlists_yaml" value="$(find mavros)/launch/apm_pluginlists.yaml" />
                <arg name="config_yaml" value="/root/carkin_ws/src/launch/apm_config.yaml" />

                <arg name="fcu_url" value="$(arg fcu_url)" />
                <arg name="gcs_url" value="$(arg gcs_url)" />
                <arg name="tgt_system" value="$(arg tgt_system)" />
                <arg name="tgt_component" value="$(arg tgt_component)" />
                <arg name="log_output" value="$(arg log_output)" />
                <arg name="fcu_protocol" value="$(arg fcu_protocol)" />
                <arg name="respawn_mavros" value="$(arg respawn_mavros)" />
        </include>
    <!-- Acelerômetro/IMU estão no grupo RAW_SENSORS (RAW_IMU, SCALED_IMU2/3, SCALED_PRESSURE).
         LANDING_TARGET nao tem grupo: o FCU so o recebe (companion->FCU), nao o transmite;
         sua taxa e controlada pelo no landing_target_sender (~rate).
         bash equivalente: rosrun mavros mavsys rate (два минуса)raw-sensors 20 -->
    
    <node pkg="mavros" type="mavsys" name="mavsys_rate_raw_sensors"
    args="rate --raw-sensors 20" output="screen" />

 <!--   <node pkg="bouncing_mission" type="visionnode.py" name="visionnode" required="true" />     -->
</launch>
